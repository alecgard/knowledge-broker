# Knowledge Broker configuration
# Copy to .env and fill in your values.
# Env vars take precedence over .env values.

# --- Optional: LLM synthesis ---
# Only needed for synthesised answers (kb query without --raw).
# Raw retrieval mode works without this.
# ANTHROPIC_API_KEY=
# KB_CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Optional: Git connector ---
# Only needed for kb ingest --git with private repos.
# Set ONE token for your host (or none to use gh CLI / device flow):
# KB_GITHUB_TOKEN=              # GitHub personal access token
# KB_GITLAB_TOKEN=              # GitLab personal access token
# KB_GIT_TOKEN=                 # Generic Git token (any host)
# KB_GITHUB_CLIENT_ID=          # Enables GitHub device flow auth as a fallback

# --- Optional: Confluence connector ---
# Only needed for kb ingest --confluence.
# KB_CONFLUENCE_BASE_URL=https://yoursite.atlassian.net
# KB_CONFLUENCE_EMAIL=you@example.com
# KB_CONFLUENCE_TOKEN=         # Atlassian API token (https://id.atlassian.com/manage-profile/security/api-tokens)

# --- Optional: Slack connector ---
# Only needed for kb ingest --slack.
# KB_SLACK_TOKEN=              # Bot User OAuth Token (xoxb-...) with channels:history, channels:read scopes
# KB_SLACK_WORKSPACE=          # Optional workspace name for display (e.g., "acme-org")

# --- Optional: GitHub Wiki connector ---
# Only needed for kb ingest --wiki. Uses KB_GITHUB_TOKEN or gh CLI for auth.

# --- Database ---
# KB_DB=kb.db

# --- Ollama (required for all modes) ---
# KB_OLLAMA_URL=http://localhost:11434
# KB_EMBEDDING_MODEL=nomic-embed-text
# KB_EMBEDDING_DIM=768
# KB_ENRICH_MODEL=qwen2.5:0.5b

# --- Server ---
# KB_LISTEN_ADDR=:8080

# --- Ingestion ---
# KB_MAX_FILE_SIZE=1048576
# KB_MAX_CHUNK_SIZE=2000
# KB_CHUNK_OVERLAP=150
# KB_WORKERS=4

# --- Query ---
# KB_DEFAULT_LIMIT=20
