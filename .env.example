# Knowledge Broker configuration
# Copy to .env and fill in your values.

# Required for queries
ANTHROPIC_API_KEY=

# Required for GitHub connector
GITHUB_TOKEN=

# Database
# KB_DB=kb.db

# Ollama
# KB_OLLAMA_URL=http://localhost:11434
# KB_OLLAMA_MODEL=nomic-embed-text
# KB_EMBEDDING_DIM=768

# Claude
# KB_CLAUDE_MODEL=claude-sonnet-4-20250514

# Server
# KB_LISTEN_ADDR=:8080

# Ingestion
# KB_MAX_FILE_SIZE=1048576
# KB_MAX_CHUNK_SIZE=2000
# KB_CHUNK_OVERLAP=150
# KB_WORKERS=4

# Query
# KB_DEFAULT_LIMIT=20
